# Local Inference
ANTHROPIC_AUTH_TOKEN=ollama
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL=http://localhost:11434
OLLAMA_CONTEXT_LENGTH=64000
GLADIUS_MODEL=glm-4.7-flash


# Cloud Inference
ANTHROPIC_AUTH_TOKEN=ollam-cloud-token
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL=https://ollama.com
OLLAMA_CONTEXT_LENGTH=64000
GLADIUS_MODEL=glm-5:cloud


# Stop conditions
# Deterministic quality stop threshold for open-ended tasks (0-100). Default: 95
GLADIUS_QUALITY_STOP_THRESHOLD=95