# ── Anthropic ──────────────────────────────────────────────────────────────────
# API key for the Anthropic Claude API.
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: override the API base URL (e.g. to route through a local Ollama proxy).
# ANTHROPIC_BASE_URL=http://localhost:11434

# Optional: bearer token passed as Authorization header (useful with Ollama).
# ANTHROPIC_AUTH_TOKEN=ollama

# ── Ollama (optional) ──────────────────────────────────────────────────────────
# Maximum context window size when using a local Ollama model.
# OLLAMA_CONTEXT_LENGTH=64000

# ── Kaggle ─────────────────────────────────────────────────────────────────────
# Credentials for the Kaggle MCP server (kaggle_tools.py).
# Alternatively, place them in ~/.kaggle/kaggle.json.
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# ── Zindi ──────────────────────────────────────────────────────────────────────
# Credentials for the Zindi MCP server (zindi_tools.py).
# ZINDI_USERNAME=your_zindi_username
# ZINDI_PASSWORD=your_zindi_password
# Index of the target challenge in the Zindi submission list (default: 0).
# ZINDI_CHALLENGE_INDEX=0

# ── Gladius ────────────────────────────────────────────────────────────────────
# Claude model to use for all agents.  Defaults to claude-sonnet-4-5 if unset.
# GLADIUS_MODEL=claude-opus-4-5

# Path to the claude-scientific-skills/scientific-skills directory.
# Only needed if you did NOT use `git clone --recurse-submodules` or want to
# point at a manually cloned copy of the submodule.
# If unset, gladius looks for the submodule at ../claude-scientific-skills/ relative
# to this repo root and warns if it isn't found.
# GLADIUS_SCIENTIFIC_SKILLS_PATH=/path/to/claude-scientific-skills/scientific-skills
